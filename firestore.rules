rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "kokoker179@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.isLoggedIn == true)
      );
    }

    // Public config
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sessions (for device tracking)
    match /sessions/{uid} {
      allow read, write: if true;
    }

    // Core Collections
    match /youth/{youthId} {
      allow read, write: if true;
    }
    
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }
    
    match /servants/{servantId} {
      allow read, write: if true;
    }

    match /marathons/{id} {
      allow read, write: if true;
    }

    match /marathonGroups/{id} {
      allow read, write: if true;
    }

    match /marathonActivityPoints/{id} {
      allow read, write: if true;
    }

    match /servantAttendance/{id} {
      allow read, write: if true;
    }

    match /visitations/{id} {
      allow read, write: if true;
    }
  }
}
