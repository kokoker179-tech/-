rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kokoker179@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    // Public config
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sessions (for device tracking)
    match /sessions/{deviceId} {
      allow read, write: if true;
    }

    // Core Collections
    match /youth/{youthId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /servants/{servantId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /marathons/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /marathonGroups/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /marathonActivityPoints/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /servantAttendance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /visitations/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
